# Ejemplo de Variables de Entorno
# INSTRUCCIONES:
# 1. Copiar este archivo: cp .env.example .env
# 2. Editar .env con valores REALES (usuario, contraseña, servidor)
# 3. NO COMMITEAR .env al repositorio - ya está en .gitignore

# SQL Server Configuration
SQL_SERVER=192.168.59.230
SQL_DATABASE=sifacturacion
SQL_DRIVER=SQL Server
SQL_USER=tu_usuario_sql_server
SQL_PASSWORD=tu_contraseña_secreta

# Optional: Debug logging
DEBUG=False
